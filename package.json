{
  "name": "phobik",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "prettier --write src",
    "prebuild": "dotenv -e .env.${env} -- expo prebuild --clean",
    "build": "eas build -p ${platform} --local -e ${env} --non-interactive",
    "build:android": "platform=android pnpm build",
    "build:ios": "platform=ios pnpm build",
    "submit": "eas submit -p ${platform} -e ${env}",
    "submit:android": "platform=android pnpm submit --path=$(find . -name '*.aab')",
    "submit:ios": "platform=ios pnpm submit --path=$(find . -name '*.ipa')",
    "update": "eas update --channel ${env} --environment ${env} --clear-cache --auto",
    "update:preview": "env=preview pnpm run update"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.148",
    "@azure/core-asynciterator-polyfill": "^1.0.2",
    "@better-auth/expo": "^1.4.18",
